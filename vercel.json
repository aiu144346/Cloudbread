{
  "version": 2,
  "rewrites": [
    { "source": "/api/config", "destination": "/api/config.js" },
    { "source": "/api/proxy", "destination": "/api/proxy.js" },
    { "source": "/api/stats(.*)", "destination": "/api/stats.js" },
    { "source": "/subscribe", "destination": "/api/subscribe.js" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
